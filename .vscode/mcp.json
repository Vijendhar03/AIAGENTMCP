{
	"servers": {
		"playwright": {
			"type": "stdio",
			"command": "/usr/bin/playwright-mcp",
			"args": [
				"--cdp-endpoint",
				"http://127.0.0.1:9222"
			]
		},
		"github": {
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-p",
				"127.0.0.1:8085:8085",
				"-e",
				"GITHUB_OAUTH_CALLBACK_PORT",
				"ghcr.io/github/github-mcp-server"
			],
			"env": {
				"GITHUB_OAUTH_CALLBACK_PORT": "8085"
			},
			"type": "stdio"
		}
	},
	"inputs": []
}